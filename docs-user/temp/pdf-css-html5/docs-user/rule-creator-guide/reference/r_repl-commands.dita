      <title class="- topic/title " xtrf="file:/Volumes/Matt_files/Git/mb/markdown-validator/docs-user/rule-creator-guide/reference/r_repl-commands.dita" xtrc="title:3;98:14">Example session</title>
      <codeblock xml:space="preserve" class="+ topic/pre pr-d/codeblock " xtrf="file:/Volumes/Matt_files/Git/mb/markdown-validator/docs-user/rule-creator-guide/reference/r_repl-commands.dita" xtrc="codeblock:1;99:39">&gt; load docs/tutorial-deploy-app.md
Loaded: /abs/path/docs/tutorial-deploy-app.md
  Metadata keys: ['title', 'ms.topic', 'ms.date', 'author', 'description']

&gt; get ms.topic
ms.topic: tutorial

&gt; query /html/body/h1 text
Result: ['Tutorial: Deploy a web application']

&gt; query //h2 count
Result: [4]

&gt; query //h2 text
Result: ['Prerequisites', 'Deploy the app', 'Test the deployment',
         'Clean up resources']

&gt; eval {"id":1,"name":"h1-must-start-with-tutorial","type":"body","query":"/html/body/h1","flag":"text","operation":"[:","value":"Tutorial:","mitigation":"H1 must start with 'Tutorial:'"}
PASS: rule id=1 name='h1-must-start-with-tutorial'

