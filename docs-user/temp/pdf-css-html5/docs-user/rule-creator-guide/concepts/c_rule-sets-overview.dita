  <title class="- topic/title " xtrf="file:/Volumes/Matt_files/Git/mb/markdown-validator/docs-user/rule-creator-guide/concepts/c_rule-sets-overview.dita" xtrc="title:1;8:10">Understanding rule sets</title>

  <prolog class="- topic/prolog " xtrf="file:/Volumes/Matt_files/Git/mb/markdown-validator/docs-user/rule-creator-guide/concepts/c_rule-sets-overview.dita" xtrc="prolog:1;10:11">
