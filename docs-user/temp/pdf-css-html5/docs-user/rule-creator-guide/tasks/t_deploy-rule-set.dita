        </info>
      </step>

      <step id="step-commit" class="- topic/li task/step " xtrf="file:/Volumes/Matt_files/Git/mb/markdown-validator/docs-user/rule-creator-guide/tasks/t_deploy-rule-set.dita" xtrc="step:5;89:30">
        <cmd class="- topic/ph task/cmd " xtrf="file:/Volumes/Matt_files/Git/mb/markdown-validator/docs-user/rule-creator-guide/tasks/t_deploy-rule-set.dita" xtrc="cmd:5;90:14">Commit the updated rule set and changelog.</cmd>
