        <cmd class="- topic/ph task/cmd " xtrf="file:/Volumes/Matt_files/Git/mb/markdown-validator/docs-user/rule-creator-guide/tasks/t_deploy-rule-set.dita" xtrc="cmd:4;76:14">Notify your author team of the changes before committing.</cmd>
        <info class="- topic/itemgroup task/info " xtrf="file:/Volumes/Matt_files/Git/mb/markdown-validator/docs-user/rule-creator-guide/tasks/t_deploy-rule-set.dita" xtrc="info:4;77:15">
          <p class="- topic/p " xtrf="file:/Volumes/Matt_files/Git/mb/markdown-validator/docs-user/rule-creator-guide/tasks/t_deploy-rule-set.dita" xtrc="p:5;78:14">Share the following information:</p>
          <ul class="- topic/ul " xtrf="file:/Volumes/Matt_files/Git/mb/markdown-validator/docs-user/rule-creator-guide/tasks/t_deploy-rule-set.dita" xtrc="ul:1;79:15">
