        <cmd class="- topic/ph task/cmd " xtrf="file:/Volumes/Matt_files/Git/mb/markdown-validator/docs-user/rule-creator-guide/tasks/t_create-rule-set.dita" xtrc="cmd:1;44:14">Create a new file named after the content type it governs.</cmd>
        <info class="- topic/itemgroup task/info " xtrf="file:/Volumes/Matt_files/Git/mb/markdown-validator/docs-user/rule-creator-guide/tasks/t_create-rule-set.dita" xtrc="info:1;45:15">
