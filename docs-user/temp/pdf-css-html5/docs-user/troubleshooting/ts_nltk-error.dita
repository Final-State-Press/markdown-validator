            <info class="- topic/itemgroup task/info " xtrf="file:/Volumes/Matt_files/Git/mb/markdown-validator/docs-user/troubleshooting/ts_nltk-error.dita" xtrc="info:3;70:19">
              <codeblock xml:space="preserve" class="+ topic/pre pr-d/codeblock " xtrf="file:/Volumes/Matt_files/Git/mb/markdown-validator/docs-user/troubleshooting/ts_nltk-error.dita" xtrc="codeblock:4;71:47">md-validate validate docs/article.md --rules rules/tutorial.json</codeblock>
            </info>
            <stepresult class="- topic/itemgroup task/stepresult " xtrf="file:/Volumes/Matt_files/Git/mb/markdown-validator/docs-user/troubleshooting/ts_nltk-error.dita" xtrc="stepresult:2;73:25">The LookupError no longer appears.</stepresult>
          </step>
