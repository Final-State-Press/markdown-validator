    <troubleSolution class="- topic/bodydiv troubleshooting/troubleSolution " xtrf="file:/Volumes/Matt_files/Git/mb/markdown-validator/docs-user/troubleshooting/ts_nltk-error.dita" xtrc="troubleSolution:2;79:22">
      <cause id="cause-ci" class="- topic/section troubleshooting/cause " xtrf="file:/Volumes/Matt_files/Git/mb/markdown-validator/docs-user/troubleshooting/ts_nltk-error.dita" xtrc="cause:2;80:28">
        <title class="- topic/title " xtrf="file:/Volumes/Matt_files/Git/mb/markdown-validator/docs-user/troubleshooting/ts_nltk-error.dita" xtrc="title:5;81:16">Cause (CI environment)</title>
        <p class="- topic/p " xtrf="file:/Volumes/Matt_files/Git/mb/markdown-validator/docs-user/troubleshooting/ts_nltk-error.dita" xtrc="p:4;82:12">The CI pipeline does not include an NLTK download step.</p>
      </cause>
      <remedy id="remedy-ci" class="- topic/section troubleshooting/remedy " xtrf="file:/Volumes/Matt_files/Git/mb/markdown-validator/docs-user/troubleshooting/ts_nltk-error.dita" xtrc="remedy:2;84:30">
        <title class="- topic/title " xtrf="file:/Volumes/Matt_files/Git/mb/markdown-validator/docs-user/troubleshooting/ts_nltk-error.dita" xtrc="title:6;85:16">Resolution (CI environment)</title>
        <p class="- topic/p " xtrf="file:/Volumes/Matt_files/Git/mb/markdown-validator/docs-user/troubleshooting/ts_nltk-error.dita" xtrc="p:5;86:12">Add the NLTK download step to your CI workflow before the validation
        step. See <xref href="../user-guide/tasks/t_integrate-github-actions.dita" class="- topic/xref " xtrf="file:/Volumes/Matt_files/Git/mb/markdown-validator/docs-user/troubleshooting/ts_nltk-error.dita" xtrc="xref:1;87:84">Add markdown-validator to a GitHub Actions workflow</xref>
        for a complete example that includes this step.</p>
      </remedy>
    </troubleSolution>

