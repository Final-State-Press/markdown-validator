            <codeph class="+ topic/ph pr-d/codeph " xtrf="file:/Volumes/Matt_files/Git/mb/markdown-validator/docs-user/troubleshooting/ts_xpath-wrong-results.dita" xtrc="codeph:9;97:21">text()</codeph> comparison.</cmd>
