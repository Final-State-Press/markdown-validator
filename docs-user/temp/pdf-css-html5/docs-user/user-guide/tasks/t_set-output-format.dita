  <taskbody class="- topic/body task/taskbody " xtrf="file:/Volumes/Matt_files/Git/mb/markdown-validator/docs-user/user-guide/tasks/t_set-output-format.dita" xtrc="taskbody:1;28:13">

    <steps class="- topic/ol task/steps " xtrf="file:/Volumes/Matt_files/Git/mb/markdown-validator/docs-user/user-guide/tasks/t_set-output-format.dita" xtrc="steps:1;30:12">

      <step id="step-text" class="- topic/li task/step " xtrf="file:/Volumes/Matt_files/Git/mb/markdown-validator/docs-user/user-guide/tasks/t_set-output-format.dita" xtrc="step:1;32:28">
        <cmd class="- topic/ph task/cmd " xtrf="file:/Volumes/Matt_files/Git/mb/markdown-validator/docs-user/user-guide/tasks/t_set-output-format.dita" xtrc="cmd:1;33:14">To produce human-readable text output (the default), run the
        validate command without the <codeph class="+ topic/ph pr-d/codeph " xtrf="file:/Volumes/Matt_files/Git/mb/markdown-validator/docs-user/user-guide/tasks/t_set-output-format.dita" xtrc="codeph:2;34:46">--format</codeph> option, or
        specify <codeph class="+ topic/ph pr-d/codeph " xtrf="file:/Volumes/Matt_files/Git/mb/markdown-validator/docs-user/user-guide/tasks/t_set-output-format.dita" xtrc="codeph:3;35:25">--format text</codeph>.</cmd>
        <info class="- topic/itemgroup task/info " xtrf="file:/Volumes/Matt_files/Git/mb/markdown-validator/docs-user/user-guide/tasks/t_set-output-format.dita" xtrc="info:1;36:15">
          <codeblock xml:space="preserve" class="+ topic/pre pr-d/codeblock " xtrf="file:/Volumes/Matt_files/Git/mb/markdown-validator/docs-user/user-guide/tasks/t_set-output-format.dita" xtrc="codeblock:1;37:43">md-validate validate docs/article.md --rules rules/tutorial.json</codeblock>
          <p class="- topic/p " xtrf="file:/Volumes/Matt_files/Git/mb/markdown-validator/docs-user/user-guide/tasks/t_set-output-format.dita" xtrc="p:1;38:14">Example output:</p>
          <codeblock xml:space="preserve" class="+ topic/pre pr-d/codeblock " xtrf="file:/Volumes/Matt_files/Git/mb/markdown-validator/docs-user/user-guide/tasks/t_set-output-format.dita" xtrc="codeblock:2;39:43">  ✓  [1]  topic-must-be-tutorial
  ✗  [4]  description-must-exist
           → Add a description field to the front matter.

Score: 5/6   FAILED</codeblock>
        </info>
      </step>

      <step id="step-json" class="- topic/li task/step " xtrf="file:/Volumes/Matt_files/Git/mb/markdown-validator/docs-user/user-guide/tasks/t_set-output-format.dita" xtrc="step:2;47:28">
