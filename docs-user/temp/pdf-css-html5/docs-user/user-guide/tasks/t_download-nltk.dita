  <title class="- topic/title " xtrf="file:/Volumes/Matt_files/Git/mb/markdown-validator/docs-user/user-guide/tasks/t_download-nltk.dita" xtrc="title:1;8:10">Download NLTK language data</title>

  <prolog class="- topic/prolog " xtrf="file:/Volumes/Matt_files/Git/mb/markdown-validator/docs-user/user-guide/tasks/t_download-nltk.dita" xtrc="prolog:1;10:11">
    <metadata class="- topic/metadata " xtrf="file:/Volumes/Matt_files/Git/mb/markdown-validator/docs-user/user-guide/tasks/t_download-nltk.dita" xtrc="metadata:1;11:15">
      <keywords class="- topic/keywords " xtrf="file:/Volumes/Matt_files/Git/mb/markdown-validator/docs-user/user-guide/tasks/t_download-nltk.dita" xtrc="keywords:1;12:17">
        <keyword class="- topic/keyword " xtrf="file:/Volumes/Matt_files/Git/mb/markdown-validator/docs-user/user-guide/tasks/t_download-nltk.dita" xtrc="keyword:1;13:18">NLTK download</keyword>
        <keyword class="- topic/keyword " xtrf="file:/Volumes/Matt_files/Git/mb/markdown-validator/docs-user/user-guide/tasks/t_download-nltk.dita" xtrc="keyword:2;14:18">punkt_tab</keyword>
        <keyword class="- topic/keyword " xtrf="file:/Volumes/Matt_files/Git/mb/markdown-validator/docs-user/user-guide/tasks/t_download-nltk.dita" xtrc="keyword:3;15:18">LookupError</keyword>
        <keyword class="- topic/keyword " xtrf="file:/Volumes/Matt_files/Git/mb/markdown-validator/docs-user/user-guide/tasks/t_download-nltk.dita" xtrc="keyword:4;16:18">sentence count rules</keyword>
        <keyword class="- topic/keyword " xtrf="file:/Volumes/Matt_files/Git/mb/markdown-validator/docs-user/user-guide/tasks/t_download-nltk.dita" xtrc="keyword:5;17:18">part-of-speech rules</keyword>
      </keywords>
      <othermeta name="description" content="Download the NLTK language data required by sentence-count and part-of-speech validation rules. Needed once per environment." class="- topic/othermeta " xtrf="file:/Volumes/Matt_files/Git/mb/markdown-validator/docs-user/user-guide/tasks/t_download-nltk.dita" xtrc="othermeta:1;20:145"/>
