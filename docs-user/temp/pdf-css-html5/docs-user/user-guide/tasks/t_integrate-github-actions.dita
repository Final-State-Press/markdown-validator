        <info class="- topic/itemgroup task/info " xtrf="file:/Volumes/Matt_files/Git/mb/markdown-validator/docs-user/user-guide/tasks/t_integrate-github-actions.dita" xtrc="info:2;61:15">
          <codeblock xml:space="preserve" class="+ topic/pre pr-d/codeblock " xtrf="file:/Volumes/Matt_files/Git/mb/markdown-validator/docs-user/user-guide/tasks/t_integrate-github-actions.dita" xtrc="codeblock:2;62:43">name: Validate documentation

on:
  pull_request:
    paths:
      - 'docs/**/*.md'

jobs:
  validate:
    runs-on: ubuntu-latest

    steps:
      - name: Check out repository
        uses: actions/checkout@v4

      - name: Set up Python
        uses: actions/setup-python@v5
        with:
          python-version: '3.12'

      - name: Cache NLTK data
        uses: actions/cache@v4
        with:
          path: ~/nltk_data
          key: nltk-punkt-tagger

      - name: Install markdown-validator
        run: pip install markdown-validator

      - name: Download NLTK language data
        run: |
          python -m nltk.downloader punkt_tab averaged_perceptron_tagger_eng

      - name: Validate documentation
        run: |
          md-validate validate docs/ \
            --rules rules/tutorial.json \
            --format json \
            --output reports/

      - name: Upload validation reports
        if: always()
        uses: actions/upload-artifact@v4
        with:
          name: validation-reports
          path: reports/</codeblock>
        </info>
      </step>

      <step id="step-understand" class="- topic/li task/step " xtrf="file:/Volumes/Matt_files/Git/mb/markdown-validator/docs-user/user-guide/tasks/t_integrate-github-actions.dita" xtrc="step:3;111:34">
