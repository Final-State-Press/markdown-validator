    <context id="context" class="- topic/section task/context " xtrf="file:/Volumes/Matt_files/Git/mb/markdown-validator/docs-user/user-guide/tasks/t_integrate-github-actions.dita" xtrc="context:1;38:27">
      <p class="- topic/p " xtrf="file:/Volumes/Matt_files/Git/mb/markdown-validator/docs-user/user-guide/tasks/t_integrate-github-actions.dita" xtrc="p:1;39:10">A GitHub Actions workflow runs automatically when you open or update a
      pull request. If the validation step exits with code <codeph class="+ topic/ph pr-d/codeph " xtrf="file:/Volumes/Matt_files/Git/mb/markdown-validator/docs-user/user-guide/tasks/t_integrate-github-actions.dita" xtrc="codeph:1;40:68">1</codeph>
