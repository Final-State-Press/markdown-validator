        <keyword class="- topic/keyword " xtrf="file:/Volumes/Matt_files/Git/mb/markdown-validator/docs-user/user-guide/concepts/c_ci-integration-overview.dita" xtrc="keyword:2;14:18">GitHub Actions validation</keyword>
