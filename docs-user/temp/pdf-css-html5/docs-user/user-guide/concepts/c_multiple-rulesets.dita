  <title class="- topic/title " xtrf="file:/Volumes/Matt_files/Git/mb/markdown-validator/docs-user/user-guide/concepts/c_multiple-rulesets.dita" xtrc="title:1;8:10">Working with multiple rule sets</title>

  <prolog class="- topic/prolog " xtrf="file:/Volumes/Matt_files/Git/mb/markdown-validator/docs-user/user-guide/concepts/c_multiple-rulesets.dita" xtrc="prolog:1;10:11">
