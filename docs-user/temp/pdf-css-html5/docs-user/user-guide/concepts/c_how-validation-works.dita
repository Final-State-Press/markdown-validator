  <title class="- topic/title " xtrf="file:/Volumes/Matt_files/Git/mb/markdown-validator/docs-user/user-guide/concepts/c_how-validation-works.dita" xtrc="title:1;8:10">How validation works</title>

  <prolog class="- topic/prolog " xtrf="file:/Volumes/Matt_files/Git/mb/markdown-validator/docs-user/user-guide/concepts/c_how-validation-works.dita" xtrc="prolog:1;10:11">
    <metadata class="- topic/metadata " xtrf="file:/Volumes/Matt_files/Git/mb/markdown-validator/docs-user/user-guide/concepts/c_how-validation-works.dita" xtrc="metadata:1;11:15">
