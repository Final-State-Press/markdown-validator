    <section id="examples" class="- topic/section " xtrf="file:/Volumes/Matt_files/Git/mb/markdown-validator/docs-user/user-guide/reference/r_cli-options.dita" xtrc="section:5;120:28">
      <title class="- topic/title " xtrf="file:/Volumes/Matt_files/Git/mb/markdown-validator/docs-user/user-guide/reference/r_cli-options.dita" xtrc="title:6;121:14">Examples</title>

      <codeblock xml:space="preserve" class="+ topic/pre pr-d/codeblock " xtrf="file:/Volumes/Matt_files/Git/mb/markdown-validator/docs-user/user-guide/reference/r_cli-options.dita" xtrc="codeblock:4;123:39"># Validate a single file with text output
md-validate validate article.md --rules rules/tutorial.json

# Validate a directory and save JSON reports
md-validate validate docs/ --rules rules/tutorial.json \
  --format json --output reports/

# Validate quietly (exit code only, no output)
md-validate --quiet validate docs/ --rules rules/tutorial.json

# Validate with debug logging
md-validate --verbose validate article.md --rules rules/tutorial.json</codeblock>
    </section>

